rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // submissions: auth required, fields validated, no updates/deletes from clients
    match /submissions/{docId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.restaurantName is string
        && request.resource.data.restaurantName.size() > 0
        && request.resource.data.restaurantName.size() <= 100
        && request.resource.data.deal is string
        && request.resource.data.deal.size() > 0
        && request.resource.data.deal.size() <= 500
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ratings: public read, auth required to write
    match /ratings/{restaurantKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // bookmarks: users can only read/write their own document
    match /bookmarks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // auto_deals: public read, no client writes (only Azure Function via Admin SDK)
    match /auto_deals/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // reviews: public read, auth required to write own entry
    match /reviews/{restaurantKey} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // wedding photo queue: public read+write (private URL is the access control)
    match /wedding/{docId} {
      allow read, write: if true;
    }

    // deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
